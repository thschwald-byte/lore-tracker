# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/
cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Environment files (Discord secrets, etc.) — loaded via dotenvy in runtime.exs.
.env
.env.*
!.env.example

# Local Mnesia dirs (umbrella root + any per-app priv that ended up with one).
/priv/mnesia/
apps/*/priv/mnesia/

# JetBrains IDE.
/.idea/
*.iml

# Per-developer Claude Code instructions (machine-local paths, OS quirks).
CLAUDE.local.md

# Claude Code per-developer settings (tool permissions etc). Project-shared
# agents under .claude/agents/ ARE checked in.
.claude/settings.local.json

# Mnesia dirs that ended up at the umbrella root (running iex without
# explicit LORE_MNESIA_DIR drops them here).
/Mnesia.*/
apps/*/Mnesia.*/


# Python sidecar build-Artefakte (Issue #418: versehentlich committet, raus)
__pycache__/
*.pyc
# große ML-Wheels (lokaler ROCm-Sidecar-Setup, gehören nicht ins Repo)
*.whl
.claude/scheduled_tasks.lock

# Issue #540: Dialyzer-PLTs (große, env-spezifische Binaries — werden gebaut,
# nicht committet; CI baut sie frisch)
/priv/plts/

# Issue #647: lokale, modell-/run-spezifische Summary-Eval-Baseline (nicht eingecheckt — LLM-Output ist nicht-deterministisch)
apps/worker/test/fixtures/summary_eval/baselines.json
