# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Environment files (Discord secrets, etc.) — loaded via dotenvy in runtime.exs.
.env
.env.*
!.env.example

# Local Mnesia dirs (umbrella root + any per-app priv that ended up with one).
/priv/mnesia/
apps/*/priv/mnesia/

# JetBrains IDE.
/.idea/
*.iml

# Per-developer Claude Code instructions (machine-local paths, OS quirks).
CLAUDE.local.md

# Claude Code per-developer settings (tool permissions etc). Project-shared
# agents under .claude/agents/ ARE checked in.
.claude/settings.local.json

# Mnesia dirs that ended up at the umbrella root (running iex without
# explicit LORE_MNESIA_DIR drops them here).
/Mnesia.*/
apps/*/Mnesia.*/

