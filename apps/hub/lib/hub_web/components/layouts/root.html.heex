<!DOCTYPE html>
<html lang="de" class="h-full bg-bg-0">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="LoreTracker" suffix=" · LoreTracker">
      {assigns[:page_title]}
    </.live_title>
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Cinzel:wght@400;600&family=Rajdhani:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="h-full font-sans antialiased">
    {@inner_content}
    <%!-- Issue #405: sticky MicLive im persistenten Root-Layout → die laufende
          Audio-Capture überlebt live_redirect-Navigation (Kampagne ↔ Dashboard).
          Mountet dormant; ohne current_user (Redirect-Seiten) ein No-Op-Div. --%>
    {live_render(@conn, HubWeb.MicLive, id: "mic-live", sticky: true)}
  </body>
</html>
