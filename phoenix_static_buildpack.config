# Tells Gigalixir's phoenix_static buildpack where the Phoenix app lives
# inside the umbrella and which Node version to use for esbuild/tailwind.
# https://github.com/gigalixir/gigalixir-buildpack-phoenix-static
phoenix_relative_path=apps/hub
node_version=20.18.0

# We use esbuild + tailwind via mix tasks (not npm), so disable npm install.
node_environment=production
phoenix_ex=phx
phoenix_dir=apps/hub
assets_path=assets
compile="mix assets.deploy"
