# Versions for Gigalixir's elixir buildpack. Pinned to match local dev.
# https://github.com/HashNuke/heroku-buildpack-elixir
elixir_version=1.19.5
erlang_version=27.3
always_rebuild=false
runtime_path=/app

# Build the digested static assets after compile, before `mix release` runs.
# Tailwind + Esbuild are managed by the Elixir hex wrappers (no Node needed),
# so this hook keeps the whole asset pipeline inside the Elixir buildpack.
hook_post_compile="mix assets.deploy"
